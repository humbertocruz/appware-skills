{
  "appware": "0.1",
  "project": "exemplo",
  "kits": ["app"],
  "targets": ["nextjs"],
  "nodes": [
    {
      "id": "tela_home",
      "coreType": "Context",
      "kitType": "app.Screen",
      "name": "Home",
